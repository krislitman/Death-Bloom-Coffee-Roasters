<%# Sign-up modal — rendered once in the layout, toggled by the dialog Stimulus controller %>

<%# Backdrop overlay %>
<div class="auth-modal__overlay hidden"
     data-dialog-target="overlay"
     data-dialog-id="sign-up"
     data-action="click->dialog#closeOnOverlay keydown.esc@window->dialog#closeOnEscape"
     aria-hidden="true">
</div>

<%# Modal panel %>
<div class="auth-modal hidden"
     data-dialog-target="modal"
     data-dialog-id="sign-up"
     role="dialog"
     aria-modal="true"
     aria-labelledby="sign-up-heading">

  <%# Close button %>
  <button class="auth-modal__close"
          data-action="dialog#close"
          aria-label="Close sign-up dialog">
    &times;
  </button>

  <%# Logo %>
  <div class="auth-modal__logo">
    <%= image_tag "logo/1. DBCR - logo - w - final files_Artboard 2 - logo 1.png",
          alt: "Death Bloom Coffee Roasters",
          width: 100,
          height: 40,
          class: "h-auto w-auto object-contain" %>
  </div>

  <h2 class="auth-modal__heading" id="sign-up-heading">Create Account</h2>

  <%= form_with url: user_registration_path,
                method: :post,
                data: { turbo: false },
                class: "auth-modal__form" do |f| %>

    <div class="auth-modal__field">
      <%= f.label :email, "Email", class: "auth-modal__label" %>
      <%= f.email_field :email,
            name: "user[email]",
            class: "auth-modal__input",
            autocomplete: "email",
            required: true,
            placeholder: "you@example.com" %>
    </div>

    <div class="auth-modal__field">
      <%= f.label :password, "Password", class: "auth-modal__label" %>
      <%= f.password_field :password,
            name: "user[password]",
            class: "auth-modal__input",
            autocomplete: "new-password",
            required: true,
            placeholder: "••••••••" %>
    </div>

    <div class="auth-modal__field">
      <%= f.label :password_confirmation, "Confirm Password", class: "auth-modal__label" %>
      <%= f.password_field :password_confirmation,
            name: "user[password_confirmation]",
            class: "auth-modal__input",
            autocomplete: "new-password",
            required: true,
            placeholder: "••••••••" %>
    </div>

    <%= f.submit "Create Account", class: "auth-modal__submit" %>
  <% end %>

  <p class="auth-modal__switch">
    Already have an account?
    <button class="auth-modal__switch-btn"
            data-action="dialog#switchTo"
            data-dialog-modal-param="sign-in">
      Sign in
    </button>
  </p>
</div>
