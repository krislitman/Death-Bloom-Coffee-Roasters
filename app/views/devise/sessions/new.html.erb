<%# Devise sign-in fallback page.
    Primary UX is the modal in the layout. This page is only reached via
    direct URL (/users/sign_in) — e.g., when Devise redirects after a
    protected action. Renders the same form in a centered card (no overlay). %>

<% content_for :title, "Sign In" %>

<div class="auth-page">
  <div class="auth-page__card">

    <div class="auth-modal__logo" style="margin-bottom: var(--space-6);">
      <%= image_tag "logo/1. DBCR - logo - w - final files_Artboard 2 - logo 1.png",
            alt: "Death Bloom Coffee Roasters",
            width: 100,
            height: 40,
            class: "h-auto w-auto object-contain" %>
    </div>

    <h1 class="auth-modal__heading">Welcome Back</h1>

    <%= form_with url: user_session_path,
                  method: :post,
                  data: { turbo: false },
                  class: "auth-modal__form" do |f| %>

      <div class="auth-modal__field">
        <%= f.label :email, "Email", class: "auth-modal__label" %>
        <%= f.email_field :email,
              name: "user[email]",
              class: "auth-modal__input",
              autocomplete: "email",
              required: true,
              placeholder: "you@example.com" %>
      </div>

      <div class="auth-modal__field">
        <%= f.label :password, "Password", class: "auth-modal__label" %>
        <%= f.password_field :password,
              name: "user[password]",
              class: "auth-modal__input",
              autocomplete: "current-password",
              required: true,
              placeholder: "••••••••" %>
      </div>

      <div class="auth-modal__remember">
        <%= f.check_box :remember_me,
              { name: "user[remember_me]", class: "auth-modal__checkbox" },
              "1", "0" %>
        <%= f.label :remember_me, "Remember me", class: "auth-modal__remember-label" %>
      </div>

      <%= f.submit "Sign In", class: "auth-modal__submit" %>
    <% end %>

    <p class="auth-modal__switch">
      Don&rsquo;t have an account?
      <%= link_to "Sign up", new_user_registration_path, class: "auth-modal__switch-btn" %>
    </p>
  </div>
</div>
