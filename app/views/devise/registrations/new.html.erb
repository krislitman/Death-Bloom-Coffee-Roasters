<%# Devise sign-up fallback page.
    Primary UX is the modal in the layout. This page is only reached via
    direct URL (/users/sign_up). Renders the same form in a centered card. %>

<% content_for :title, "Create Account" %>

<div class="auth-page">
  <div class="auth-page__card">

    <div class="auth-modal__logo" style="margin-bottom: var(--space-6);">
      <%= image_tag "logo/1. DBCR - logo - w - final files_Artboard 2 - logo 1.png",
            alt: "Death Bloom Coffee Roasters",
            width: 100,
            height: 40,
            class: "h-auto w-auto object-contain" %>
    </div>

    <h1 class="auth-modal__heading">Create Account</h1>

    <% if Flipper.enabled?(:google_auth) %>
      <%= button_to user_google_oauth2_omniauth_authorize_path,
            method: :post,
            data: { turbo: false },
            class: "auth-modal__oauth-btn" do %>
        <svg class="auth-modal__oauth-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Continue with Google
      <% end %>
      <div class="auth-modal__divider"><span>or</span></div>
    <% end %>

    <%= form_with url: user_registration_path,
                  method: :post,
                  data: { turbo: false },
                  class: "auth-modal__form" do |f| %>

      <div class="auth-modal__field">
        <%= f.label :email, "Email", class: "auth-modal__label" %>
        <%= f.email_field :email,
              name: "user[email]",
              class: "auth-modal__input",
              autocomplete: "email",
              required: true,
              placeholder: "you@example.com" %>
      </div>

      <div class="auth-modal__field">
        <%= f.label :password, "Password", class: "auth-modal__label" %>
        <%= f.password_field :password,
              name: "user[password]",
              class: "auth-modal__input",
              autocomplete: "new-password",
              required: true,
              placeholder: "••••••••" %>
      </div>

      <div class="auth-modal__field">
        <%= f.label :password_confirmation, "Confirm Password", class: "auth-modal__label" %>
        <%= f.password_field :password_confirmation,
              name: "user[password_confirmation]",
              class: "auth-modal__input",
              autocomplete: "new-password",
              required: true,
              placeholder: "••••••••" %>
      </div>

      <%= f.submit "Create Account", class: "auth-modal__submit" %>
    <% end %>

    <p class="auth-modal__switch">
      Already have an account?
      <%= link_to "Sign in", new_user_session_path, class: "auth-modal__switch-btn" %>
    </p>
  </div>
</div>
