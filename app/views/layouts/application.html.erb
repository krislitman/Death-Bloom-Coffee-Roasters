<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? yield(:title) + " — Death Bloom" : "Death Bloom Coffee Roasters" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Death Bloom Coffee Roasters">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="cart-drawer dialog">
    <% if Flipper.enabled?(:announcement_bar) %>
      <%= render "shared/announcement_bar" %>
    <% end %>

    <%= render "shared/nav" %>

    <%# Cart drawer overlay + panel (Stimulus targets must share a controller scope) %>
    <div class="cart-drawer__overlay"
         data-cart-drawer-target="overlay"
         data-action="click->cart-drawer#closeOnOverlay">
    </div>
    <div class="cart-drawer" data-cart-drawer-target="drawer" role="dialog" aria-label="Shopping cart">
      <div class="cart-drawer__header">
        <h2>Your Cart</h2>
        <button class="cart-drawer__close"
                data-action="cart-drawer#close"
                aria-label="Close cart">
          &times;
        </button>
      </div>
      <div class="cart-drawer__body">
        <div id="cart-items">
          <% cart_items = current_cart.cart_items.includes(:coffee) %>
          <% if cart_items.any? %>
            <%= render cart_items %>
          <% else %>
            <p class="cart__empty">Your cart is empty.</p>
          <% end %>
        </div>
      </div>
      <div class="cart-drawer__footer" id="cart-summary">
        <p class="cart__total">Total: <%= number_to_currency(current_cart.total_cents / 100.0) %></p>
        <%= link_to "View Cart", cart_path, class: "btn btn--secondary" %>
        <%= link_to "Checkout", checkout_path, class: "btn btn--primary" %>
      </div>
    </div>

    <% if notice.present? %>
      <p class="flash flash--notice" role="status"><%= notice %></p>
    <% end %>
    <% if alert.present? %>
      <p class="flash flash--alert" role="alert"><%= alert %></p>
    <% end %>

    <%# Auth modals — hidden by default, opened by the dialog Stimulus controller %>
    <%= render "shared/auth_modal_sign_in" %>
    <%= render "shared/auth_modal_sign_up" %>

    <%= yield %>

    <%= render "shared/footer" %>
  </body>
</html>
